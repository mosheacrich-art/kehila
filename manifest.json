{
  "id": "/",
  "name": "Jabad Barcelona",
  "short_name": "Jabad BCN",
  "description": "App de la comunidad Jabad Barcelona — Eventos, noticias, donativos y más.",
  "start_url": "/home.html",
  "scope": "/",
  "display": "standalone",
  "display_override": ["standalone", "minimal-ui", "browser"],
  "background_color": "#1B2E5E",
  "theme_color": "#1b2e5e",
  "orientation": "portrait-primary",
  "lang": "es",
  "dir": "auto",
  "categories": ["lifestyle", "social"],
  "prefer_related_applications": false,
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "share_target": {
    "action": "/home.html",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "file_handlers": [
    {
      "action": "/shiurim.html",
      "accept": {
        "application/pdf": [".pdf"]
      }
    }
  ],
  "protocol_handlers": [
    {
      "protocol": "web+kehila",
      "url": "/home.html?uri=%s"
    }
  ],
  "edge_side_panel": {
    "preferred_width": 400
  },
  "note_taking": {
    "new_note_url": "/rav.html"
  },
  "scope_extensions": [
    { "origin": "https://bcnkehila.com" }
  ],
  "widgets": [
    {
      "name": "Jabad BCN",
      "description": "Próximos eventos y noticias de la comunidad",
      "tag": "kehila-widget",
      "screenshots": [
        {
          "src": "img/screenshot-1.png",
          "sizes": "1080x1920",
          "label": "Widget Kehila"
        }
      ],
      "icons": [
        { "src": "img/icon-192.png", "sizes": "192x192" }
      ],
      "auth": false,
      "update": 86400
    }
  ],
  "shortcuts": [
    {
      "name": "Eventos",
      "short_name": "Eventos",
      "description": "Ver eventos de la comunidad",
      "url": "/eventos.html",
      "icons": [{ "src": "img/icon-96.png", "sizes": "96x96", "type": "image/png" }]
    },
    {
      "name": "Noticias",
      "short_name": "Noticias",
      "description": "Últimas noticias de la kehila",
      "url": "/noticias.html",
      "icons": [{ "src": "img/icon-96.png", "sizes": "96x96", "type": "image/png" }]
    },
    {
      "name": "Donativos",
      "short_name": "Donativos",
      "description": "Apoya a la comunidad",
      "url": "/donativos.html",
      "icons": [{ "src": "img/icon-96.png", "sizes": "96x96", "type": "image/png" }]
    },
    {
      "name": "Pregunta al Rav",
      "short_name": "Rav",
      "description": "Consulta al rabino",
      "url": "/rav.html",
      "icons": [{ "src": "img/icon-96.png", "sizes": "96x96", "type": "image/png" }]
    }
  ],
  "icons": [
    { "src": "img/icon-48.png",   "sizes": "48x48",     "type": "image/png", "purpose": "any" },
    { "src": "img/icon-72.png",   "sizes": "72x72",     "type": "image/png", "purpose": "any" },
    { "src": "img/icon-96.png",   "sizes": "96x96",     "type": "image/png", "purpose": "any" },
    { "src": "img/icon-144.png",  "sizes": "144x144",   "type": "image/png", "purpose": "any" },
    { "src": "img/icon-168.png",  "sizes": "168x168",   "type": "image/png", "purpose": "any" },
    { "src": "img/icon-192.png",  "sizes": "192x192",   "type": "image/png", "purpose": "any maskable" },
    { "src": "img/icon-512.png",  "sizes": "512x512",   "type": "image/png", "purpose": "any maskable" },
    { "src": "img/icon-1024.png", "sizes": "1024x1024", "type": "image/png", "purpose": "any" }
  ],
  "screenshots": [
    {
      "src": "img/screenshot-1.png",
      "sizes": "1080x1920",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Pantalla de inicio — Kehilá Jabad Barcelona"
    },
    {
      "src": "img/screenshot-2.png",
      "sizes": "1080x1920",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Eventos de la comunidad"
    }
  ]
}
